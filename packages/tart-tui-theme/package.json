{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@humanlayer/tart-tui-theme",
	"version": "0.0.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"module": "src/main.tsx",
	"exports": {
		".": "./src/main.tsx",
		"./tactical": "./src/theme/tactical.ts",
		"./theme-types": "./src/theme/types.ts",
		"./glow": "./src/hud/GlowEffect.ts",
		"./postfx": "./src/hud/postfx.ts"
	},
	"scripts": {
		"start": "bun run src/main.tsx",
		"augmented": "bun run src/main.tsx --theme augmented",
		"tactical": "bun run src/main.tsx --theme tactical",
		"demo": "bun run src/main.tsx --demo",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@opentui/core": "catalog:",
		"@opentui/react": "0.4.3",
		"react": "19.2.0"
	},
	"devDependencies": {
		"@types/react": "19.2.2",
		"typescript": "catalog:"
	}
}
